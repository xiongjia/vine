{
  "name": "vine",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,mdx,json,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,mdx,json,yaml,yml}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=18.12"
  }
}
